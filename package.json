{
  "name": "capital-copilot-fe",
  "version": "0.27.0",
  "description": "Capital Copilot's Front-End",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prestart": "yarn docs:graphql",
    "build": "ng build",
    "prebuild": "yarn docs:graphql",
    "watch": "ng build --watch --configuration development",
    "prepare": "husky install",
    "test": "ng test --watch=false",
    "serve:ssr:capital-copilot-fe": "node dist/capital-copilot-fe/server/server.mjs",
    "lint": "ng lint",
    "lint:scss": "stylelint \"**/*.scss\"",
    "lint:scss:fix": "stylelint \"**/*.scss\" --fix",
    "lint:md3": "node scripts/check-md3-compliance.js",
    "lint:md3:component": "node scripts/check-md3-compliance.js --checklist",
    "lint:all": "yarn lint && yarn lint:scss && yarn lint:md3",
    "scss:track": "scripts/track-scss-size.sh",
    "css:analyze": "node scripts/analyze-css-size.js",
    "css:baseline": "yarn build && node scripts/analyze-css-size.js --baseline",
    "css:dev": "yarn build && node scripts/analyze-css-size.js --dev",
    "css:compare": "node scripts/analyze-css-size.js --compare",
    "generate": "graphql-codegen",
    "docs:graphql": "spectaql spectaql-config.yml 2>&1 | grep -v 'Deprecation Warning' | grep -v 'legacy-js-api' | grep -v 'More info' | grep -v '@import' | grep -v '╷' | grep -v '╵' | grep -v 'scss' || true",
    "check-copyright": "node scripts/check-copyright.js"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write",
      "yarn check-copyright"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "yarn check-copyright"
    ],
    "*.html": [
      "yarn check-copyright"
    ],
    "*.scss": [
      "stylelint --fix",
      "yarn check-copyright"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.17",
    "@angular/cdk": "^18.0.6",
    "@angular/common": "^19.2.17",
    "@angular/compiler": "^19.2.17",
    "@angular/core": "^19.2.17",
    "@angular/forms": "^19.2.17",
    "@angular/material": "^18.0.6",
    "@angular/platform-browser": "^19.2.17",
    "@angular/platform-browser-dynamic": "^19.2.17",
    "@angular/router": "^19.2.17",
    "@apollo/client": "^3.0.0",
    "@stripe/stripe-js": "^5.6.0",
    "angular-oauth2-oidc": "19",
    "apollo-angular": "^7.2.1",
    "apollo-upload-client": "^18.0.1",
    "axios": "^1.7.4",
    "graphql": "^16.9.0",
    "marked": "^16.4.0",
    "mermaid": "^11.12.1",
    "rxjs": "~7.8.0",
    "spectaql": "^3.0.5",
    "tslib": "^2.3.0",
    "undici": "^6.19.4",
    "ws": "^8.18.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.19",
    "@angular/cli": "^19.2.19",
    "@angular/compiler-cli": "^19.2.17",
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^4.1.1",
    "@graphql-codegen/typescript-apollo-angular": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^4.3.1",
    "@types/apollo-upload-client": "^18.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/p5": "^1.7.6",
    "angular-eslint": "18.4.3",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.4",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^15.2.8",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "purgecss": "^7.0.2",
    "stylelint": "^16.26.1",
    "stylelint-config-clean-order": "^8.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "6",
    "stylelint-scss": "^6.12.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.15.0"
  },
  "repository": "git+https://github.com/Perpetuator-LLC/capital-copilot-fe.git",
  "keywords": [
    "investing",
    "ai",
    "finance",
    "crypto",
    "research",
    "backtesting",
    "trends",
    "valuation"
  ],
  "author": "Nik Cimino",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/Perpetuator-LLC/capital-copilot-fe/issues"
  },
  "homepage": "https://github.com/Perpetuator-LLC/capital-copilot-fe#readme",
  "main": "index.js"
}
