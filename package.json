{
  "name": "capital-copilot-fe",
  "version": "0.32.0",
  "description": "Capital Copilot's Front-End",
  "resolutions": {
    "minimatch": "^10.2.1",
    "handlebars": ">=4.7.9"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ssr": "ng serve --configuration production",
    "build": "ng build",
    "build:prod": "yarn docs:graphql && ng build",
    "build:stage": "yarn docs:graphql && ng build --configuration staging",
    "watch": "ng build --watch --configuration development",
    "prepare": "husky install",
    "test": "ng test --watch=false",
    "serve:ssr:capital-copilot-fe": "node dist/capital-copilot-fe/server/server.mjs",
    "lint": "ng lint",
    "lint:scss": "stylelint \"**/*.scss\"",
    "lint:scss:fix": "stylelint \"**/*.scss\" --fix",
    "lint:md3": "node scripts/check-md3-compliance.js",
    "lint:md3:component": "node scripts/check-md3-compliance.js --checklist",
    "lint:scss:unused": "node scripts/check-unused-scss.js",
    "lint:scss:unused:strict": "node scripts/check-unused-scss.js --strict",
    "lint:all": "yarn lint && yarn lint:scss && yarn lint:md3 && yarn lint:scss:unused:strict && yarn format:check",
    "scss:track": "scripts/track-scss-size.sh",
    "css:analyze": "node scripts/analyze-css-size.js",
    "css:baseline": "yarn build && node scripts/analyze-css-size.js --baseline",
    "css:dev": "yarn build && node scripts/analyze-css-size.js --dev",
    "css:compare": "node scripts/analyze-css-size.js --compare",
    "generate": "graphql-codegen",
    "theme:generate": "tsx scripts/generate-palettes.ts",
    "favicon": "node scripts/generate-favicons.cjs",
    "docs:graphql": "spectaql spectaql-config.yml",
    "check-copyright": "node scripts/check-copyright.js"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write",
      "yarn check-copyright --fix"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "yarn check-copyright --fix"
    ],
    "*.html": [
      "prettier --write",
      "yarn check-copyright --fix"
    ],
    "*.scss": [
      "prettier --write",
      "stylelint --fix --allow-empty-input",
      "yarn check-copyright --fix",
      "node scripts/check-unused-scss.js --strict --files"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.4",
    "@angular/cdk": "^21.1.4",
    "@angular/common": "^21.1.4",
    "@angular/compiler": "^21.1.4",
    "@angular/core": "^21.1.4",
    "@angular/forms": "^21.1.4",
    "@angular/material": "^21.1.4",
    "@angular/platform-browser": "^21.1.4",
    "@angular/platform-browser-dynamic": "^21.1.4",
    "@angular/platform-server": "^21.1.4",
    "@angular/router": "^21.1.4",
    "@angular/ssr": "^21.2.9",
    "@apollo/client": "^4.1.4",
    "@stripe/stripe-js": "^8.7.0",
    "angular-gridster2": "^21.0.0",
    "angular-oauth2-oidc": "^20.0.2",
    "apollo-angular": "^13.0.0",
    "apollo-upload-client": "^19.0.0",
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "graphql-ws": "^6.0.7",
    "marked": "^17.0.2",
    "mermaid": "^11.12.2",
    "ngx-echarts": "^21.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0",
    "ws": "^8.19.0",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.4",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-apollo-angular": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^5.0.7",
    "@material/material-color-utilities": "^0.4.0",
    "@types/apollo-upload-client": "^19.0.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.2.3",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "favicons": "^7.2.0",
    "form-data": "^4.0.5",
    "husky": "^9.1.4",
    "jasmine-core": "^6.0.1",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "spectaql": "^3.0.5",
    "stylelint": "^17.3.0",
    "stylelint-config-clean-order": "^8.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-scss": "^7.0.0",
    "svgo": "^4.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "repository": "git+https://github.com/Perpetuator-LLC/capital-copilot-fe.git",
  "keywords": [
    "investing",
    "ai",
    "finance",
    "crypto",
    "research",
    "backtesting",
    "trends",
    "valuation"
  ],
  "author": "Nik Cimino",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/Perpetuator-LLC/capital-copilot-fe/issues"
  },
  "homepage": "https://github.com/Perpetuator-LLC/capital-copilot-fe#readme",
  "main": "index.js"
}
