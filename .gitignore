# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Custom for this project
/src/environments/environment.ts
/src/environments/environment.prod.ts
/src/environments/environment.staging.ts
/logs/*
# Prevent accidental additions of paths starting with ~/ (home directory references)
~/*
# Explicitly ignore any browser profile data
**/browser/Default/
**/browser/ChromeFeatureState
**/ai_link/browser/
# But allow CSS size reports (except dev snapshots)
!/logs/css-size-reports/
/logs/css-size-reports/*.dev.json
# And allow SCSS size tracking baseline
!/logs/scss-sizes/
!/logs/scss-sizes/*.dev.json
/logs/scss-sizes/*

# Generated documentation
/docs/graphql

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log
yarn-error.log
package-lock.json

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Miscellaneous
/.angular/cache
.sass-cache/
.connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# System files
.DS_Store
Thumbs.db

# Additional entries from old .gitignore
.integration/bazel/bazel-*
*.log
# CircleCI temporary file for cache key computation.
# See `save_month_to_file` in `.circleci/config.yml`.
month.txt
# Include when developing application packages.
pubspec.lock
.devcontainer/*
!.devcontainer/README.md
!.devcontainer/recommended-devcontainer.json
!.devcontainer/recommended-Dockerfile
*.swo
*.swp
modules/.settings
modules/.vscode
.vimrc
.nvimrc
# Don't check in secret files
*secret.js
# build-analytics
.build-analytics
# rollup-test output
/modules/rollup-test/dist/
# User specific bazel settings
.bazelrc.user
# User specific ng-dev settings
.ng-dev.user*
.notes.md
baseline.json
# Ignore .history for the xyz.local-history VSCode extension
.history
# Husky
.husky/_
aio/content/examples/.DS_Store
# Ignore cache created with the Angular CLI.
.angular/
*.scss.*

# Claude Code auto-generated context (session-start hook)
.claude/
!.claude/settings.json
config.bat
