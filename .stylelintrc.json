{
  "extends": ["stylelint-config-standard-scss", "stylelint-config-clean-order"],
  "plugins": ["stylelint-scss"],
  "rules": {
    "scss/comment-no-empty": null,
    "scss/double-slash-comment-whitespace-inside": null,
    "comment-empty-line-before": null,
    "no-descending-specificity": null,
    "selector-class-pattern": null,
    "custom-property-pattern": null,
    "scss/dollar-variable-pattern": null,
    "scss/at-mixin-pattern": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "no-duplicate-selectors": true,
    "color-hex-length": "long",
    "length-zero-no-unit": true,
    "declaration-no-important": [
      true,
      {
        "severity": "warning",
        "message": "Avoid !important - use specificity or Material component variants instead"
      }
    ],
    "max-nesting-depth": [
      4,
      {
        "severity": "warning",
        "message": "Nesting too deep - consider refactoring or using Material components"
      }
    ],
    "selector-max-id": [
      0,
      {
        "severity": "warning"
      }
    ],
    "scss/at-import-partial-extension": null,
    "import-notation": null,
    "at-rule-no-unknown": null,
    "scss/at-rule-no-unknown": true,
    "scss/no-global-function-names": null,
    "alpha-value-notation": "number",

    "comment-word-disallowed-list": [
      ["/ng-deep/", "/::ng-deep/", "::v-deep"],
      {
        "severity": "error",
        "message": "::ng-deep is deprecated and breaks encapsulation. Target Material classes directly or use CSS variables."
      }
    ],

    "selector-pseudo-element-disallowed-list": [
      "ng-deep",
      {
        "severity": "error",
        "message": "::ng-deep is deprecated. Use CSS custom properties (--md-sys-color-*) or target Material classes directly."
      }
    ],

    "declaration-property-value-disallowed-list": [
      {
        "/^(margin|padding|gap|top|right|bottom|left)$/": [
          "/^(?!(0|4px|8px|12px|16px|20px|24px|28px|32px|36px|40px|44px|48px|52px|56px|60px|64px|68px|72px|76px|80px|calc\\(|auto|inherit|initial|unset))[0-9]+(px|rem|em)$/"
        ],
        "/^border-radius$/": [
          "/^(?!(0|4px|8px|12px|16px|20px|24px|28px|32px|36px|40px|48px|64px|999px|calc\\(|auto|inherit|initial|unset))[0-9]+(px|rem|em)$/"
        ],
        "/^(width|height|min-width|max-width|min-height|max-height)$/": [
          "/^(?!(0|4px|8px|12px|16px|20px|24px|28px|32px|36px|40px|44px|48px|52px|56px|60px|64px|68px|72px|76px|80px|84px|88px|92px|96px|100px|112px|128px|144px|160px|176px|192px|208px|224px|240px|256px|272px|288px|304px|320px|336px|352px|368px|384px|400px|416px|432px|448px|464px|480px|496px|512px|calc\\(|auto|100%|inherit|initial|unset))[0-9]+(px|rem|em|%)$/"
        ],
        "/^font-size$/": [
          "/^(?!(0|10px|11px|12px|13px|14px|15px|16px|17px|18px|19px|20px|22px|24px|26px|28px|30px|32px|36px|40px|44px|48px|calc\\())[0-9]+(px|rem|em)$/"
        ]
      },
      {
        "severity": "warning",
        "message": "Use MD3 4px grid values (4, 8, 16, 24, 32, 48) instead of arbitrary values. For dynamic values, use calc() with design tokens."
      }
    ],

    "color-no-hex": [
      true,
      {
        "severity": "warning",
        "message": "Use MD3 design tokens (--md-sys-color-*) instead of hex colors for theme support."
      }
    ],

    "function-disallowed-list": [
      ["rgb", "rgba", "hsl", "hsla"],
      {
        "severity": "warning",
        "message": "Use MD3 design tokens (--md-sys-color-*) instead of color functions for theme support."
      }
    ],

    "selector-pseudo-class-disallowed-list": [
      "/^ng-deep$/",
      {
        "severity": "error",
        "message": "::ng-deep is deprecated. Use CSS custom properties or target Material classes directly."
      }
    ],

    "property-disallowed-list": [
      ["clip"],
      {
        "severity": "error",
        "message": "The 'clip' property is deprecated. Use 'clip-path' instead."
      }
    ],

    "scss/at-mixin-argumentless-call-parentheses": "always",

    "declaration-block-no-duplicate-properties": [
      true,
      {
        "severity": "error",
        "message": "Duplicate property found. Remove the duplicate."
      }
    ],

    "block-no-empty": [
      true,
      {
        "severity": "error",
        "message": "Empty blocks should be removed."
      }
    ],

    "font-family-no-missing-generic-family-keyword": [
      true,
      {
        "severity": "warning",
        "message": "Add a generic font family fallback (e.g., sans-serif)"
      }
    ]
  }
}
