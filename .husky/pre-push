# Block pushing the obfuscated dropper to ANY remote. The original infection
# reached origin/main because push was unguarded — this closes that gap.
# Pure grep, runs before any node tooling.
ROOT="$(git rev-parse --show-toplevel)"
bash "$ROOT/scripts/scan-for-malware.sh" || exit 1

# Load NVM in non-interactive shell
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Use the Node version from .nvmrc
if command -v nvm >/dev/null 2>&1; then
  nvm use
fi

# Dependency vulnerability scan — fails only on high or critical CVEs
# yarn audit exit codes are bitmasks (4=moderate, 8=high, 16=critical), so we grep output instead
AUDIT_OUTPUT=$(yarn audit 2>&1) || true
if echo "$AUDIT_OUTPUT" | grep -qE "^│ (high|critical)"; then
  echo "High or Critical CVEs found — run 'yarn audit' to see details. Push blocked."
  exit 1
fi

# Project-wide lint checks that aren't covered by lint-staged in pre-commit.
# lint-staged only sees staged files, so these catch issues introduced via
# --no-verify, partial staging, or cross-file regressions (e.g. an SCSS class
# becoming unused because its consumer was deleted in a different file).
yarn lint:md3 --strict
yarn lint:scss:unused:strict

# Full suite with the coverage ratchet (scripts/check-coverage.js minimums) —
# mirrors the CI test job, which runs the same script headless.
npm run test:coverage
