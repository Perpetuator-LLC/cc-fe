# Load NVM in non-interactive shell
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Use the Node version from .nvmrc
nvm use

# Dependency vulnerability scan — fails on critical CVEs only
# (high CVEs are checked in CI to avoid blocking on transitive dev tooling deps)
yarn audit --audit-level=critical

npm test

