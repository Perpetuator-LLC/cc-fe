# Refuses commits re-introducing the obfuscated payload injected into
# eslint.config.js / commitlint.config.js during the 2025-10 / 2026-02 incident.
added_lines=$(git diff --cached -U0 | grep '^+[^+]' || true)
if printf '%s' "$added_lines" | grep -qFe "global['!']" -e "String.fromCharCode(127)" -e '_$_1e42'; then
  echo "ABORT: staged changes contain a known malware payload signature."
  echo "  Inspect with: git diff --cached"
  exit 1
fi

# Load NVM in non-interactive shell
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Use the Node version from .nvmrc
nvm use

# Secret scanning — requires: brew install gitleaks
if command -v gitleaks &> /dev/null; then
  gitleaks protect --staged -v
else
  echo "⚠️  gitleaks not found — secret scanning skipped. Run: brew install gitleaks"
fi

npx lint-staged

