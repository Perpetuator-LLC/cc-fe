#
# Docker build context exclusions
# Reduces build context size and prevents unnecessary files from being copied

# Dependencies - installed fresh during build
node_modules/
.npm/
.yarn/

# Build outputs - generated during build
dist/
.angular/

# Version control
.git/
.gitignore

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs and debugging
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/
# NOTE: *.spec.ts is intentionally NOT excluded. The Dockerfile's `build` stage
# (source + devDependencies) is what CI targets to run the unit suite inside the
# image, so it needs the specs in the build context. They never reach the
# runtime image — the `production` stage copies only dist/, never source.

# Documentation and notes
docs/
notes/
*.md
!README.md

# Environment files (sensitive)
.env
.env.*
sample.env

# Development scripts and tools
scripts/
*.sh
# … but allow the container entrypoint, which IS needed by the build.
!docker-entrypoint.sh

# Temporary files
tmp/
temp/
.cache/

# OS generated files
.DS_Store
Thumbs.db

# Husky git hooks
.husky/

# Other config files not needed in container
.editorconfig
.eslintrc*
.prettierrc*
eslint.config.js
commitlint.config.js
ecosystem.config.cjs
