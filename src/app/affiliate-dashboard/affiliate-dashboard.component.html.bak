<!-- Copyright (c) 2025 Perpetuator LLC -->
<div class="affiliate-dashboard-container">

  @if (checkingEligibility) {
    <div class="loading-container">
      <mat-spinner></mat-spinner>
      <p>Checking eligibility...</p>
    </div>
  } @else if (eligibility && !eligibility.isEligible) {
    <div class="not-eligible-container">
      <mat-card class="eligibility-card">
        <mat-card-content>
          @if (!eligibility.hasPaidOrder) {
            <div class="eligibility-message purchase-required">
              <mat-icon>shopping_cart</mat-icon>
              <div class="message-content">
                <h2>Purchase Required</h2>
                <p class="reason">{{ eligibility.reason }}</p>
                <p class="detail">
                  To join our affiliate program, you must first make a purchase on our platform.
                  This helps ensure our affiliate program is used by active members of our community.
                </p>
                <div class="actions">
                  <button mat-raised-button color="primary" (click)="navigateToPurchase()">
                    Purchase Credits
                  </button>
                </div>
              </div>
            </div>
          } @else {
            <div class="eligibility-message not-eligible">
              <mat-icon>block</mat-icon>
              <div class="message-content">
                <h2>Not Accessible</h2>
                <p class="reason">{{ eligibility.reason }}</p>
                <p class="detail">
                  Please contact support if you require assistance.
                </p>
              </div>
            </div>
          }
        </mat-card-content>
      </mat-card>

      <!-- Admin Panel - Always Accessible for Admins Even When Not Eligible -->
      @if (isAdmin() || canApproveCodeChanges()) {
        <mat-card class="admin-control-panel">
          <mat-card-content>
            <h2>Affiliate Admin Control Panel</h2>
            <p class="admin-notice">
              <mat-icon>admin_panel_settings</mat-icon>
              You have administrative access. Use the controls below to manage the affiliate program.
            </p>

            @if (isAdmin()) {
              <!-- Platform Financial Stats -->
              <div class="admin-section financial-stats-section">
                <h3>
                  <mat-icon>account_balance</mat-icon>
                  Platform Financial Status
                </h3>
                @if (loadingFinancialStats) {
                  <div class="loading-container-small">
                    <mat-spinner diameter="30"></mat-spinner>
                    <span>Loading financial data...</span>
                  </div>
                } @else if (platformFinancialStats) {
                  <div class="financial-stats-grid">
                    <!-- Stripe Account Balance -->
                    <div class="stat-card stripe-balance">
                      <div class="stat-header">
                        <mat-icon>account_balance_wallet</mat-icon>
                        <h4>Stripe Account Balance</h4>
                      </div>
                      <div class="stat-body">
                        <div class="stat-main">
                          <span class="stat-label">Total Balance:</span>
                          <span class="stat-value primary">${{ formatCentsAsDollars(platformFinancialStats.stripeTotalBalanceCents) }}</span>
                        </div>
                        <div class="stat-breakdown">
                          <div class="stat-item">
                            <span class="stat-sublabel">Available:</span>
                            <span class="stat-subvalue">${{ formatCentsAsDollars(platformFinancialStats.stripeAvailableBalanceCents) }}</span>
                          </div>
                          <div class="stat-item">
                            <span class="stat-sublabel">Pending:</span>
                            <span class="stat-subvalue">${{ formatCentsAsDollars(platformFinancialStats.stripePendingBalanceCents) }}</span>
                          </div>
                        </div>
                        <div class="stat-meta">
                          <mat-icon class="mode-icon" [class.live]="platformFinancialStats.stripeIsLiveMode">
                            {{ platformFinancialStats.stripeIsLiveMode ? 'verified' : 'science' }}
                          </mat-icon>
                          <span class="mode-text">{{ platformFinancialStats.stripeIsLiveMode ? 'Live Mode' : 'Test Mode' }}</span>
                        </div>
                      </div>
                    </div>

                    <!-- Outstanding Affiliate Credits -->
                    <div class="stat-card affiliate-credits">
                      <div class="stat-header">
                        <mat-icon>people</mat-icon>
                        <h4>Outstanding Affiliate Credits</h4>
                      </div>
                      <div class="stat-body">
                        <div class="stat-main">
                          <span class="stat-label">Total Liability:</span>
                          <span class="stat-value warning">${{ formatCentsAsDollars(platformFinancialStats.totalAffiliateCreditsCents) }}</span>
                        </div>
                        <div class="stat-breakdown">
                          <div class="stat-item">
                            <span class="stat-sublabel">Credits:</span>
                            <span class="stat-subvalue">{{ platformFinancialStats.totalAffiliateCredits | number }}</span>
                          </div>
                          <div class="stat-item">
                            <span class="stat-sublabel">Pending Conversions:</span>
                            <span class="stat-subvalue">${{ formatCentsAsDollars(platformFinancialStats.pendingConversionCents) }}</span>
                          </div>
                        </div>
                        <div class="stat-info">
                          <mat-icon class="info-icon">info</mat-icon>
                          <span class="info-text">{{ platformFinancialStats.totalAffiliateCredits | number }} credits = ${{ platformFinancialStats.totalAffiliateCreditsDollars | number: '1.2-2' }}</span>
                        </div>
                      </div>
                    </div>

                    <!-- Financial Difference -->
                    <div class="stat-card financial-difference" [class.surplus]="getFinancialDifference() > 0" [class.deficit]="getFinancialDifference() < 0">
                      <div class="stat-header">
                        <mat-icon>{{ getFinancialDifference() > 0 ? 'trending_up' : getFinancialDifference() < 0 ? 'trending_down' : 'horizontal_rule' }}</mat-icon>
                        <h4>Balance vs. Liability</h4>
                      </div>
                      <div class="stat-body">
                        <div class="stat-main">
                          <span class="stat-label">{{ getFinancialDifference() > 0 ? 'Surplus:' : getFinancialDifference() < 0 ? 'Deficit:' : 'Difference:' }}</span>
                          <span class="stat-value" [class.positive]="getFinancialDifference() > 0" [class.negative]="getFinancialDifference() < 0">
                            {{ getFinancialDifference() > 0 ? '+' : '' }}${{ formatCentsAsDollars(Math.abs(getFinancialDifference())) }}
                          </span>
                        </div>
                        <div class="stat-breakdown">
                          <div class="stat-item">
                            <span class="stat-sublabel">Available Buffer:</span>
                            <span class="stat-subvalue">${{ formatCentsAsDollars(platformFinancialStats.availablePayoutBufferCents) }}</span>
                          </div>
                        </div>
                        <div class="stat-status">
                          <mat-icon [class.success]="isFinancialHealthGood()" [class.error]="!isFinancialHealthGood()">
                            {{ isFinancialHealthGood() ? 'check_circle' : 'warning' }}
                          </mat-icon>
                          <span [class.success-text]="isFinancialHealthGood()" [class.error-text]="!isFinancialHealthGood()">
                            {{ isFinancialHealthGood() ? 'Can cover all outstanding credits' : 'Insufficient funds to cover all credits' }}
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="financial-actions">
                    <button mat-raised-button color="primary" (click)="loadPlatformFinancialStats()">
                      <mat-icon>refresh</mat-icon>
                      Refresh Financial Data
                    </button>
                  </div>
                } @else {
                  <div class="empty-state-small">
                    <mat-icon>error_outline</mat-icon>
                    <p>Failed to load financial data</p>
                  </div>
                }
              </div>

              <!-- Affiliate Network Graph -->
              <div class="admin-section graph-section">
                <h3>
                  <mat-icon>account_tree</mat-icon>
                  Affiliate Network Visualization
                </h3>
                <p class="section-description">
                  View an interactive graph showing all affiliate relationships and referral chains in the network.
                </p>
                <button mat-raised-button color="primary" (click)="openAffiliateGraph()">
                  <mat-icon>account_tree</mat-icon>
                  View Network Graph
                </button>
              </div>

              <!-- Global Program Settings -->
              <div class="admin-section program-settings-section">
                <h3>Global Program Settings</h3>
                @if (loadingProgramSettings) {
                  <div class="loading-container-small">
                    <mat-spinner diameter="30"></mat-spinner>
                    <span>Loading...</span>
                  </div>
                } @else if (programSettings) {
                  <div class="program-status-row">
                    <div class="status-indicator">
                      <mat-icon [class.enabled]="programSettings.isEnabled" [class.disabled]="!programSettings.isEnabled">
                        {{ programSettings.isEnabled ? 'check_circle' : 'cancel' }}
                      </mat-icon>
                      <span class="status-text">
                        Affiliate Program: <strong>{{ programSettings.isEnabled ? 'ENABLED' : 'DISABLED' }}</strong>
                      </span>
                    </div>
                    <button
                      mat-raised-button
                      [color]="programSettings.isEnabled ? 'warn' : 'primary'"
                      (click)="toggleAffiliateProgramEnabled()"
                      [disabled]="updatingProgramSettings"
                    >
                      @if (updatingProgramSettings) {
                        <mat-spinner diameter="20"></mat-spinner>
                      } @else {
                        <mat-icon>{{ programSettings.isEnabled ? 'block' : 'check_circle' }}</mat-icon>
                      }
                      {{ programSettings.isEnabled ? 'Disable' : 'Enable' }}
                    </button>
                  </div>
                  @if (!programSettings.isEnabled && programSettings.disabledMessage) {
                    <div class="disabled-message-display">
                      <strong>Current Disabled Message:</strong>
                      <p>{{ programSettings.disabledMessage }}</p>
                    </div>
                  }
                }
              </div>

              <!-- User Account Management -->
              <div class="admin-section user-management-section">
                <h3>Suspend/Restore User Accounts</h3>
                <div class="user-search">
                  <mat-form-field appearance="outline" class="search-field">
                    <mat-label>Search by username (min 3 characters)</mat-label>
                    <input matInput [(ngModel)]="searchUsername" (keyup.enter)="searchUser()" />
                    <mat-icon matSuffix>search</mat-icon>
                  </mat-form-field>
                  <button mat-raised-button color="primary" (click)="searchUser()" [disabled]="searchingUser">
                    @if (searchingUser) {
                      <mat-spinner diameter="20"></mat-spinner>
                    } @else {
                      Search
                    }
                  </button>
                </div>

                @if (searchedUsers.length > 0) {
                  <div class="searched-users-list">
                    @for (user of searchedUsers; track user.uuid) {
                      <div class="searched-user-card">
                        <div class="user-info">
                          <mat-icon>person</mat-icon>
                          <div>
                            <strong>{{ user.username }}</strong>
                            <span class="user-status">
                              @if (user.hasAffiliateProfile) {
                                <span class="badge affiliate">
                                  <mat-icon>verified</mat-icon>
                                  Affiliate Member
                                </span>
                                @if (user.eligibilityStatus) {
                                  <span class="badge status-badge"
                                        [class.active]="user.eligibilityStatus === 'active'"
                                        [class.suspended]="user.eligibilityStatus === 'suspended'"
                                        [class.under-review]="user.eligibilityStatus === 'under_review'">
                                    <mat-icon>{{ getStatusIcon(user.eligibilityStatus) }}</mat-icon>
                                    {{ getStatusLabel(user.eligibilityStatus) }}
                                  </span>
                                }
                                @if (user.isActive !== undefined) {
                                  <span class="badge network-badge"
                                        [class.network-open]="user.isActive"
                                        [class.network-closed]="!user.isActive">
                                    <mat-icon>{{ user.isActive ? 'group' : 'group_remove' }}</mat-icon>
                                    {{ user.isActive ? 'Accepting' : 'Closed' }}
                                  </span>
                                }
                              } @else {
                                <span class="badge no-profile">Not in program</span>
                              }
                            </span>
                          </div>
                        </div>
                        @if (user.hasAffiliateProfile) {
                          <div class="user-actions">
                            <button
                              mat-raised-button
                              color="warn"
                              (click)="lockUserAccount(user.uuid, user.username)"
                              [disabled]="updatingUserEligibility || user.eligibilityStatus === 'suspended' || user.eligibilityStatus === 'under_review'"
                              matTooltip="Suspend or place account under review"
                            >
                              <mat-icon>lock</mat-icon>
                              Restrict Account
                            </button>
                            <button
                              mat-raised-button
                              color="primary"
                              (click)="restoreUserAccount(user.uuid, user.username)"
                              [disabled]="updatingUserEligibility || user.eligibilityStatus === 'active'"
                              matTooltip="Restore user's affiliate account"
                            >
                              <mat-icon>lock_open</mat-icon>
                              Restore
                            </button>
                            <button
                              mat-raised-button
                              [color]="user.isActive ? 'accent' : 'primary'"
                              (click)="toggleNetworkStatus(user.uuid, user.username, user.isActive ?? true)"
                              [disabled]="updatingUserEligibility"
                              [matTooltip]="user.isActive ? 'Close network (prevent new sign-ups)' : 'Open network (allow new sign-ups)'"
                            >
                              <mat-icon>{{ user.isActive ? 'group_remove' : 'group_add' }}</mat-icon>
                              {{ user.isActive ? 'Close Network' : 'Open Network' }}
                            </button>
                          </div>
                        }
                      </div>
                    }
                  </div>
                }
              </div>
            }

            <!-- Pending Code Change Requests -->
            @if (canApproveCodeChanges()) {
              <div class="admin-section code-requests-section">
                <h3>Pending Code Change Requests</h3>

                @if (loadingAdminRequests) {
                  <div class="loading-container-small">
                    <mat-spinner diameter="30"></mat-spinner>
                    <span>Loading requests...</span>
                  </div>
                } @else if (adminPendingRequests.length === 0) {
                  <div class="no-data-small">No pending requests</div>
                } @else {
                  <div class="requests-table">
                    <table mat-table [dataSource]="adminPendingRequests" class="compact-table">
                      <ng-container matColumnDef="user">
                        <th mat-header-cell *matHeaderCellDef>User</th>
                        <td mat-cell *matCellDef="let request">
                          <strong>{{ request.user.username }}</strong>
                        </td>
                      </ng-container>

                      <ng-container matColumnDef="codes">
                        <th mat-header-cell *matHeaderCellDef>Code Change</th>
                        <td mat-cell *matCellDef="let request">
                          <div class="code-change-inline">
                            <span class="old-code">{{ request.currentCode }}</span>
                            <mat-icon>arrow_forward</mat-icon>
                            <span class="new-code">{{ request.requestedCode }}</span>
                          </div>
                        </td>
                      </ng-container>

                      <ng-container matColumnDef="actions">
                        <th mat-header-cell *matHeaderCellDef>Actions</th>
                        <td mat-cell *matCellDef="let request">
                          <div class="action-buttons-inline">
                            <button
                              mat-icon-button
                              color="primary"
                              (click)="approveCodeChangeRequest(request.uuid)"
                              matTooltip="Approve"
                            >
                              <mat-icon>check</mat-icon>
                            </button>
                            <button
                              mat-icon-button
                              color="warn"
                              (click)="rejectCodeChangeRequest(request.uuid)"
                              matTooltip="Reject"
                            >
                              <mat-icon>close</mat-icon>
                            </button>
                          </div>
                        </td>
                      </ng-container>

                      <tr mat-header-row *matHeaderRowDef="['user', 'codes', 'actions']"></tr>
                      <tr mat-row *matRowDef="let row; columns: ['user', 'codes', 'actions'];"></tr>
                    </table>
                  </div>
                }
              </div>
            }
          </mat-card-content>
        </mat-card>
      }
    </div>
  } @else if (loading) {
    <div class="loading-container">
      <mat-spinner></mat-spinner>
      <p>Loading affiliate dashboard...</p>
    </div>
  } @else {
    <div class="dashboard-content">
      <h1 class="page-title">Affiliate Dashboard</h1>

      <!-- Account Status Display -->
      @if (profile && (
        (profile.eligibilityStatus && profile.eligibilityStatus !== 'active') ||
        !profile.isActive
      )) {
        <mat-card class="status-card">
          <mat-card-content>
            <div class="status-display">
              @if (profile.eligibilityStatus && profile.eligibilityStatus !== 'active') {
                <div class="status-item">
                  <mat-icon [class]="getStatusColor(profile.eligibilityStatus)">
                    {{ getStatusIcon(profile.eligibilityStatus) }}
                  </mat-icon>
                  <div class="status-text">
                    <strong>Account Status:</strong>
                    <span class="status-label">{{ getStatusLabel(profile.eligibilityStatus) }}</span>
                  </div>
                </div>
              }

              @if (profile.isActive !== undefined) {
                <div class="status-item">
                  <mat-icon [class]="profile.isActive ? 'status-active' : 'status-inactive'">
                    {{ profile.isActive ? 'group' : 'group_remove' }}
                  </mat-icon>
                  <div class="status-text">
                    <strong>Network Status:</strong>
                    <span class="status-label">{{ profile.isActive ? 'Accepting Members' : 'Closed' }}</span>
                  </div>
                </div>
              }
            </div>

            <!-- Network Joining Warning -->
            @if (!isNetworkJoinable(profile) && getNetworkJoiningMessage(profile)) {
              <div class="network-warning"
                   [class.suspended]="profile.eligibilityStatus === 'suspended'"
                   [class.under-review]="profile.eligibilityStatus === 'under_review'"
                   [class.network-closed]="!profile.isActive && (!profile.eligibilityStatus || profile.eligibilityStatus === 'active')">
                <mat-icon>{{ getStatusIcon(profile.eligibilityStatus) || 'block' }}</mat-icon>
                <p>{{ getNetworkJoiningMessage(profile) }}</p>
              </div>
            }

            <!-- Eligibility Message from Admin -->
            @if (profile.eligibilityMessage) {
              <div class="eligibility-message-display">
                <mat-icon>info</mat-icon>
                <p>{{ profile.eligibilityMessage }}</p>
              </div>
            }
          </mat-card-content>
        </mat-card>
      }

      <div class="stats-grid">
        <mat-card class="stat-card">
          <mat-card-content>
            <div class="stat-icon">
              <mat-icon>payments</mat-icon>
            </div>
            <div class="stat-value">{{ stats?.totalAffiliateCredits || 0 }}</div>
            <div class="stat-label">Total Earnings (Credits)</div>
          </mat-card-content>
        </mat-card>

        <mat-card class="stat-card">
          <mat-card-content>
            <div class="stat-icon">
              <mat-icon>group</mat-icon>
            </div>
            <div class="stat-value">{{ stats?.totalReferrals || 0 }}</div>
            <div class="stat-label">Total Referrals</div>
          </mat-card-content>
        </mat-card>

        <mat-card class="stat-card">
          <mat-card-content>
            <div class="stat-icon">
              <mat-icon>person</mat-icon>
            </div>
            <div class="stat-value">{{ stats?.tier1Referrals || 0 }}</div>
            <div class="stat-label">Direct Referrals (10%)</div>
          </mat-card-content>
        </mat-card>

        <mat-card class="stat-card">
          <mat-card-content>
            <div class="stat-icon">
              <mat-icon>people</mat-icon>
            </div>
            <div class="stat-value">{{ stats?.tier2Referrals || 0 }}</div>
            <div class="stat-label">Second Level (5%)</div>
          </mat-card-content>
        </mat-card>
      </div>

      <!-- Available Balance - Moved to top for prominence -->
      <mat-card class="balance-card">
        <mat-card-content>
          <h2>Available Balance</h2>
          <div class="balance-value">{{ getAvailableBalance() }} Credits</div>
          <div class="conversion-actions">
            <button mat-raised-button color="primary" (click)="openConvertDialog('credits')">
              <mat-icon>swap_horiz</mat-icon>
              Convert to Credits
            </button>
            <button mat-raised-button (click)="openConvertDialog('cash')">
              <mat-icon>attach_money</mat-icon>
              Request Cash Payout
            </button>
          </div>
        </mat-card-content>
      </mat-card>

      <!-- Stripe Connect Status -->
      @if (profile) {
        <mat-card class="stripe-status-card" [class.incomplete]="!profile.stripeOnboardingCompleted">
          <mat-card-content>
            <h2>Payment Account Status</h2>
            @if (!profile.stripeAccountId) {
              <div class="stripe-status not-setup">
                <mat-icon>account_balance</mat-icon>
                <div class="status-content">
                  <h3>Stripe Account Required</h3>
                  <p>To receive cash payouts, you need to create a Stripe Connect account. This ensures secure and compliant payments.</p>
                  <button mat-raised-button color="primary" (click)="startStripeOnboarding()">
                    <mat-icon>add_circle</mat-icon>
                    Setup Payment Account
                  </button>
                </div>
              </div>
            } @else if (!profile.stripeOnboardingCompleted) {
              <div class="stripe-status incomplete">
                <mat-icon>pending</mat-icon>
                <div class="status-content">
                  <h3>Setup Incomplete</h3>
                  <p>Your Stripe account setup is not complete. Please finish the onboarding process to enable cash payouts.</p>
                  <div class="button-group">
                    <button mat-raised-button color="accent" (click)="continueStripeOnboarding()">
                      <mat-icon>arrow_forward</mat-icon>
                      Continue Setup
                    </button>
                    <button mat-stroked-button (click)="skipStripeSetup()">
                      <mat-icon>home</mat-icon>
                      Skip for Now
                    </button>
                  </div>
                </div>
              </div>
            } @else {
              <div class="stripe-status complete">
                <mat-icon>check_circle</mat-icon>
                <div class="status-content">
                  <h3>Payment Account Active</h3>
                  <div class="stripe-details">
                    @if (profile.stripeCountry) {
                      <div class="detail-item">
                        <span class="label">Country:</span>
                        <span class="value">{{ profile.stripeCountry }}</span>
                      </div>
                    }
                    <div class="detail-item">
                      <span class="label">Payouts:</span>
                      <span class="value" [class.enabled]="profile.stripePayoutsEnabled" [class.disabled]="!profile.stripePayoutsEnabled">
                        {{ profile.stripePayoutsEnabled ? 'Enabled' : 'Disabled' }}
                      </span>
                    </div>
                  </div>
                  <button mat-raised-button (click)="openStripeDashboard()">
                    <mat-icon>open_in_new</mat-icon>
                    View Stripe Dashboard
                  </button>
                </div>
              </div>
            }
          </mat-card-content>
        </mat-card>
      }

      @if (pendingCodeChangeRequest) {
        <mat-card class="pending-request-card">
          <mat-card-content>
            <div class="pending-request-content">
              <div class="pending-request-icon">
                <mat-icon>schedule</mat-icon>
              </div>
              <div class="pending-request-info">
                <h3>Code Change Request Pending</h3>
                <p>Requested code: <strong>{{ pendingCodeChangeRequest.requestedCode }}</strong></p>
                <p class="request-date">Submitted {{ formatDate(pendingCodeChangeRequest.requestedAt) }}</p>
                @if (pendingCodeChangeRequest.reason) {
                  <p class="request-reason">Reason: {{ pendingCodeChangeRequest.reason }}</p>
                }
              </div>
              <div class="pending-request-actions">
                <button mat-raised-button (click)="cancelPendingCodeChangeRequest()">
                  <mat-icon>cancel</mat-icon>
                  Cancel Request
                </button>
              </div>
            </div>
          </mat-card-content>
        </mat-card>
      }

      <mat-card class="link-card">
        <mat-card-content>
          <h2>Your Affiliate Link</h2>
          <div class="link-section">
            <div class="link-display">
              <span class="link-text">{{ getAffiliateLink() }}</span>
              <button mat-icon-button (click)="copyLink()">
                <mat-icon>content_copy</mat-icon>
              </button>
            </div>
            <div class="action-buttons">
              <button mat-raised-button color="primary" (click)="copyLink()">
                <mat-icon>content_copy</mat-icon>
                Copy Link
              </button>
              <button mat-raised-button (click)="openCodeChangeDialog()" [disabled]="!!pendingCodeChangeRequest">
                <mat-icon>edit</mat-icon>
                Change Code
              </button>
            </div>
            <app-share-buttons
              [shareUrl]="getAffiliateLink()"
              [title]="'Join me on Capital Copilot!'"
              [description]="'Sign up using my affiliate link and we both benefit.'"
            ></app-share-buttons>
          </div>
        </mat-card-content>
      </mat-card>

      <mat-card class="brand-image-card">
        <mat-card-content>
          <h2>Brand Image</h2>
          <p class="help-text">Upload your brand logo (max 1MB, JPEG/PNG/GIF/WEBP)</p>

          <!-- Current Image Display -->
          @if (profile?.brandImageUrl && !imagePreview) {
            <div class="brand-image-preview">
              <img
                [src]="profile!.brandImageUrl"
                alt="Brand Image"
                (error)="onImageError()"
                loading="lazy"
              >
              <div class="image-actions">
                <button
                  mat-icon-button
                  color="warn"
                  (click)="deleteBrandImage()"
                  [disabled]="uploadingImage"
                  matTooltip="Delete image"
                >
                  <mat-icon>delete</mat-icon>
                </button>
              </div>
            </div>
          }

          <!-- Image Preview (during upload) -->
          @if (imagePreview) {
            <div class="brand-image-preview uploading">
              <img [src]="imagePreview" alt="Preview">
              @if (uploadingImage) {
                <div class="upload-overlay">
                  <mat-spinner diameter="40"></mat-spinner>
                  <p>Uploading...</p>
                </div>
              }
            </div>
          }

          <!-- Drag and Drop Area -->
          <div
            class="upload-dropzone"
            [class.dragging]="isDragging"
            [class.has-image]="profile?.brandImageUrl"
            (dragover)="onDragOver($event)"
            (dragleave)="onDragLeave($event)"
            (drop)="onDrop($event)"
          >
            <input
              type="file"
              #fileInput
              (change)="onFileSelected($event)"
              accept=".jpg,.jpeg,.png,.gif,.webp"
              style="display: none;"
              [disabled]="uploadingImage"
            >

            <div class="dropzone-content">
              <mat-icon>cloud_upload</mat-icon>
              <p class="dropzone-text">Drag & drop your image here</p>
              <p class="dropzone-or">or</p>
              <button
                mat-raised-button
                color="primary"
                (click)="fileInput.click()"
                [disabled]="uploadingImage"
              >
                <mat-icon>upload</mat-icon>
                {{ profile?.brandImageUrl ? 'Change' : 'Upload' }} Image
              </button>
            </div>
          </div>

          <div class="upload-requirements">
            <p><strong>Requirements:</strong></p>
            <ul>
              <li>Maximum file size: 1MB</li>
              <li>Supported formats: JPEG, PNG, GIF, WEBP</li>
              <li>Recommended size: 512x512 pixels</li>
            </ul>
          </div>
        </mat-card-content>
      </mat-card>

      <mat-tab-group class="history-tabs">
        <mat-tab label="Earnings History">
          <div class="table-container">
            @if (credits.length > 0) {
              <table mat-table [dataSource]="credits" class="history-table">
                <ng-container matColumnDef="date">
                  <th mat-header-cell *matHeaderCellDef>Date</th>
                  <td mat-cell *matCellDef="let credit">{{ formatDate(credit.createdAt) }}</td>
                </ng-container>

                <ng-container matColumnDef="from">
                  <th mat-header-cell *matHeaderCellDef>From</th>
                  <td mat-cell *matCellDef="let credit">{{ credit.sourceUser?.username || 'System' }}</td>
                </ng-container>

                <ng-container matColumnDef="type">
                  <th mat-header-cell *matHeaderCellDef>Type</th>
                  <td mat-cell *matCellDef="let credit">{{ getTierDescription(credit.tier) }}</td>
                </ng-container>

                <ng-container matColumnDef="amount">
                  <th mat-header-cell *matHeaderCellDef>Amount</th>
                  <td mat-cell *matCellDef="let credit">{{ credit.amount }} credits</td>
                </ng-container>

                <tr mat-header-row *matHeaderRowDef="creditsDisplayedColumns"></tr>
                <tr mat-row *matRowDef="let row; columns: creditsDisplayedColumns;"></tr>
              </table>
            } @else {
              <div class="no-data">No earnings yet</div>
            }
          </div>
        </mat-tab>

        <mat-tab label="Conversion History">
          <div class="table-container">
            @if (conversions.length > 0) {
              <table mat-table [dataSource]="conversions" class="history-table">
                <ng-container matColumnDef="date">
                  <th mat-header-cell *matHeaderCellDef>Date</th>
                  <td mat-cell *matCellDef="let conversion">{{ formatDate(conversion.createdAt) }}</td>
                </ng-container>

                <ng-container matColumnDef="type">
                  <th mat-header-cell *matHeaderCellDef>Type</th>
                  <td mat-cell *matCellDef="let conversion">{{ getConversionTypeDisplay(conversion.conversionType) }}</td>
                </ng-container>

                <ng-container matColumnDef="amount">
                  <th mat-header-cell *matHeaderCellDef>Amount</th>
                  <td mat-cell *matCellDef="let conversion">{{ conversion.affiliateCreditAmount }}</td>
                </ng-container>

                <ng-container matColumnDef="status">
                  <th mat-header-cell *matHeaderCellDef>Status</th>
                  <td mat-cell *matCellDef="let conversion">
                    <span class="status-badge" [ngClass]="getStatusClass(conversion.status)">{{ formatStatus(conversion.status) }}</span>
                  </td>
                </ng-container>

                <ng-container matColumnDef="details">
                  <th mat-header-cell *matHeaderCellDef>Details</th>
                  <td mat-cell *matCellDef="let conversion">
                    @if (conversion.status === 'rejected' && conversion.rejectionReason) {
                      <span class="rejection-reason" [matTooltip]="conversion.rejectionReason">
                        <mat-icon>info</mat-icon>
                        {{ conversion.rejectionReason.length > 30 ? conversion.rejectionReason.substring(0, 30) + '...' : conversion.rejectionReason }}
                      </span>
                    } @else if (conversion.status === 'completed' && conversion.stripeTransferId) {
                      <span class="transfer-id" [matTooltip]="'Stripe Transfer ID: ' + conversion.stripeTransferId">
                        <mat-icon>check_circle</mat-icon>
                        Paid
                      </span>
                    } @else if (conversion.status === 'under_review') {
                      <span class="under-review">Pending admin review</span>
                    } @else {
                      <span class="no-details">—</span>
                    }
                  </td>
                </ng-container>

                <tr mat-header-row *matHeaderRowDef="conversionsDisplayedColumns"></tr>
                <tr mat-row *matRowDef="let row; columns: conversionsDisplayedColumns;"></tr>
              </table>
            } @else {
              <div class="no-data">No conversions yet</div>
            }
          </div>
        </mat-tab>
      </mat-tab-group>

      <!-- Admin Control Panel - At Bottom -->
      @if (isAdmin() || canApproveCodeChanges()) {
        <mat-card class="admin-control-panel">
          <mat-card-content>
            <h2>Affiliate Admin Control Panel</h2>

            @if (isAdmin()) {
              <!-- Platform Financial Stats -->
              <div class="admin-section financial-stats-section">
                <h3>
                  <mat-icon>account_balance</mat-icon>
                  Platform Financial Status
                </h3>
                @if (loadingFinancialStats) {
                  <div class="loading-container-small">
                    <mat-spinner diameter="30"></mat-spinner>
                    <span>Loading financial data...</span>
                  </div>
                } @else if (platformFinancialStats) {
                  <div class="financial-stats-grid">
                    <!-- Stripe Account Balance -->
                    <div class="stat-card stripe-balance">
                      <div class="stat-header">
                        <mat-icon>account_balance_wallet</mat-icon>
                        <h4>Stripe Account Balance</h4>
                      </div>
                      <div class="stat-body">
                        <div class="stat-main">
                          <span class="stat-label">Total Balance:</span>
                          <span class="stat-value primary">${{ formatCentsAsDollars(platformFinancialStats.stripeTotalBalanceCents) }}</span>
                        </div>
                        <div class="stat-breakdown">
                          <div class="stat-item">
                            <span class="stat-sublabel">Available:</span>
                            <span class="stat-subvalue">${{ formatCentsAsDollars(platformFinancialStats.stripeAvailableBalanceCents) }}</span>
                          </div>
                          <div class="stat-item">
                            <span class="stat-sublabel">Pending:</span>
                            <span class="stat-subvalue">${{ formatCentsAsDollars(platformFinancialStats.stripePendingBalanceCents) }}</span>
                          </div>
                        </div>
                        <div class="stat-meta">
                          <mat-icon class="mode-icon" [class.live]="platformFinancialStats.stripeIsLiveMode">
                            {{ platformFinancialStats.stripeIsLiveMode ? 'verified' : 'science' }}
                          </mat-icon>
                          <span class="mode-text">{{ platformFinancialStats.stripeIsLiveMode ? 'Live Mode' : 'Test Mode' }}</span>
                        </div>
                      </div>
                    </div>

                    <!-- Outstanding Affiliate Credits -->
                    <div class="stat-card affiliate-credits">
                      <div class="stat-header">
                        <mat-icon>people</mat-icon>
                        <h4>Outstanding Affiliate Credits</h4>
                      </div>
                      <div class="stat-body">
                        <div class="stat-main">
                          <span class="stat-label">Total Liability:</span>
                          <span class="stat-value warning">${{ formatCentsAsDollars(platformFinancialStats.totalAffiliateCreditsCents) }}</span>
                        </div>
                        <div class="stat-breakdown">
                          <div class="stat-item">
                            <span class="stat-sublabel">Credits:</span>
                            <span class="stat-subvalue">{{ platformFinancialStats.totalAffiliateCredits | number }}</span>
                          </div>
                          <div class="stat-item">
                            <span class="stat-sublabel">Pending Conversions:</span>
                            <span class="stat-subvalue">${{ formatCentsAsDollars(platformFinancialStats.pendingConversionCents) }}</span>
                          </div>
                        </div>
                        <div class="stat-info">
                          <mat-icon class="info-icon">info</mat-icon>
                          <span class="info-text">{{ platformFinancialStats.totalAffiliateCredits | number }} credits = ${{ platformFinancialStats.totalAffiliateCreditsDollars | number: '1.2-2' }}</span>
                        </div>
                      </div>
                    </div>

                    <!-- Financial Difference -->
                    <div class="stat-card financial-difference" [class.surplus]="getFinancialDifference() > 0" [class.deficit]="getFinancialDifference() < 0">
                      <div class="stat-header">
                        <mat-icon>{{ getFinancialDifference() > 0 ? 'trending_up' : getFinancialDifference() < 0 ? 'trending_down' : 'horizontal_rule' }}</mat-icon>
                        <h4>Balance vs. Liability</h4>
                      </div>
                      <div class="stat-body">
                        <div class="stat-main">
                          <span class="stat-label">{{ getFinancialDifference() > 0 ? 'Surplus:' : getFinancialDifference() < 0 ? 'Deficit:' : 'Difference:' }}</span>
                          <span class="stat-value" [class.positive]="getFinancialDifference() > 0" [class.negative]="getFinancialDifference() < 0">
                            {{ getFinancialDifference() > 0 ? '+' : '' }}${{ formatCentsAsDollars(Math.abs(getFinancialDifference())) }}
                          </span>
                        </div>
                        <div class="stat-breakdown">
                          <div class="stat-item">
                            <span class="stat-sublabel">Available Buffer:</span>
                            <span class="stat-subvalue">${{ formatCentsAsDollars(platformFinancialStats.availablePayoutBufferCents) }}</span>
                          </div>
                        </div>
                        <div class="stat-status">
                          <mat-icon [class.success]="isFinancialHealthGood()" [class.error]="!isFinancialHealthGood()">
                            {{ isFinancialHealthGood() ? 'check_circle' : 'warning' }}
                          </mat-icon>
                          <span [class.success-text]="isFinancialHealthGood()" [class.error-text]="!isFinancialHealthGood()">
                            {{ isFinancialHealthGood() ? 'Can cover all outstanding credits' : 'Insufficient funds to cover all credits' }}
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="financial-actions">
                    <button mat-raised-button color="primary" (click)="loadPlatformFinancialStats()">
                      <mat-icon>refresh</mat-icon>
                      Refresh Financial Data
                    </button>
                  </div>
                } @else {
                  <div class="empty-state-small">
                    <mat-icon>error_outline</mat-icon>
                    <p>Failed to load financial data</p>
                  </div>
                }
              </div>

              <!-- Affiliate Network Graph -->
              <div class="admin-section graph-section">
                <h3>
                  <mat-icon>account_tree</mat-icon>
                  Affiliate Network Visualization
                </h3>
                <p class="section-description">
                  View an interactive graph showing all affiliate relationships and referral chains in the network.
                </p>
                <button mat-raised-button color="primary" (click)="openAffiliateGraph()">
                  <mat-icon>account_tree</mat-icon>
                  View Network Graph
                </button>
              </div>

              <!-- Global Program Settings -->
              <div class="admin-section program-settings-section">
                <h3>Global Program Settings</h3>
                @if (loadingProgramSettings) {
                  <div class="loading-container-small">
                    <mat-spinner diameter="30"></mat-spinner>
                    <span>Loading...</span>
                  </div>
                } @else if (programSettings) {
                  <div class="program-status-row">
                <div class="status-indicator">
                  <mat-icon [class.enabled]="programSettings.isEnabled" [class.disabled]="!programSettings.isEnabled">
                    {{ programSettings.isEnabled ? 'check_circle' : 'cancel' }}
                  </mat-icon>
                  <span class="status-text">
                    Affiliate Program: <strong>{{ programSettings.isEnabled ? 'ENABLED' : 'DISABLED' }}</strong>
                  </span>
                </div>
                <button
                  mat-raised-button
                  [color]="programSettings.isEnabled ? 'warn' : 'primary'"
                  (click)="toggleAffiliateProgramEnabled()"
                  [disabled]="updatingProgramSettings"
                >
                  @if (updatingProgramSettings) {
                    <mat-spinner diameter="20"></mat-spinner>
                  } @else {
                    <mat-icon>{{ programSettings.isEnabled ? 'block' : 'check_circle' }}</mat-icon>
                  }
                  {{ programSettings.isEnabled ? 'Disable' : 'Enable' }}
                </button>
              </div>
                }
              </div>

              <!-- User Account Management -->
              <div class="admin-section user-management-section">
            <h3>Suspend/Restore User Accounts</h3>
            <div class="user-search">
              <mat-form-field appearance="outline" class="search-field">
                <mat-label>Search by username (min 3 characters)</mat-label>
                <input matInput [(ngModel)]="searchUsername" (keyup.enter)="searchUser()" />
                <mat-icon matSuffix>search</mat-icon>
              </mat-form-field>
              <button mat-raised-button color="primary" (click)="searchUser()" [disabled]="searchingUser">
                @if (searchingUser) {
                  <mat-spinner diameter="20"></mat-spinner>
                } @else {
                  Search
                }
              </button>
            </div>

            @if (searchedUsers.length > 0) {
              <div class="searched-users-list">
                @for (user of searchedUsers; track user.uuid) {
                  <div class="searched-user-card">
                    <div class="user-info">
                      <mat-icon>person</mat-icon>
                      <div>
                        <strong>{{ user.username }}</strong>
                        <span class="user-status">
                          @if (user.hasAffiliateProfile) {
                            <span class="badge affiliate">
                              <mat-icon>verified</mat-icon>
                              Affiliate Member
                            </span>
                            @if (user.eligibilityStatus) {
                              <span class="badge status-badge"
                                    [class.active]="user.eligibilityStatus === 'active'"
                                    [class.suspended]="user.eligibilityStatus === 'suspended'"
                                    [class.under-review]="user.eligibilityStatus === 'under_review'">
                                <mat-icon>{{ getStatusIcon(user.eligibilityStatus) }}</mat-icon>
                                {{ getStatusLabel(user.eligibilityStatus) }}
                              </span>
                            }
                            @if (user.isActive !== undefined) {
                              <span class="badge network-badge"
                                    [class.network-open]="user.isActive"
                                    [class.network-closed]="!user.isActive">
                                <mat-icon>{{ user.isActive ? 'group' : 'group_remove' }}</mat-icon>
                                {{ user.isActive ? 'Accepting' : 'Closed' }}
                              </span>
                            }
                          } @else {
                            <span class="badge no-profile">Not in program</span>
                          }
                        </span>
                      </div>
                    </div>
                    @if (user.hasAffiliateProfile) {
                      <div class="user-actions">
                        <button
                          mat-raised-button
                          color="warn"
                          (click)="lockUserAccount(user.uuid, user.username)"
                          [disabled]="updatingUserEligibility || user.eligibilityStatus === 'suspended' || user.eligibilityStatus === 'under_review'"
                          matTooltip="Suspend or place account under review"
                        >
                          <mat-icon>lock</mat-icon>
                          Restrict Account
                        </button>
                        <button
                          mat-raised-button
                          color="primary"
                          (click)="restoreUserAccount(user.uuid, user.username)"
                          [disabled]="updatingUserEligibility || user.eligibilityStatus === 'active'"
                          matTooltip="Restore user's affiliate account"
                        >
                          <mat-icon>lock_open</mat-icon>
                          Restore
                        </button>
                        <button
                          mat-raised-button
                          [color]="user.isActive ? 'accent' : 'primary'"
                          (click)="toggleNetworkStatus(user.uuid, user.username, user.isActive ?? true)"
                          [disabled]="updatingUserEligibility"
                          [matTooltip]="user.isActive ? 'Close network (prevent new sign-ups)' : 'Open network (allow new sign-ups)'"
                        >
                          <mat-icon>{{ user.isActive ? 'group_remove' : 'group_add' }}</mat-icon>
                          {{ user.isActive ? 'Close Network' : 'Open Network' }}
                        </button>
                      </div>
                    }
                  </div>
                }
              </div>
            }
          </div>
            }

            <!-- Pending Code Change Requests -->
            @if (canApproveCodeChanges()) {
              <div class="admin-section code-requests-section">
                <h3>Pending Code Change Requests</h3>

                @if (loadingAdminRequests) {
                  <div class="loading-container-small">
                    <mat-spinner diameter="30"></mat-spinner>
                    <span>Loading requests...</span>
                  </div>
                } @else if (adminPendingRequests.length === 0) {
                  <div class="no-data-small">No pending requests</div>
                } @else {
                  <div class="requests-table">
                    <table mat-table [dataSource]="adminPendingRequests" class="compact-table">
                      <ng-container matColumnDef="user">
                        <th mat-header-cell *matHeaderCellDef>User</th>
                        <td mat-cell *matCellDef="let request">
                          <strong>{{ request.user.username }}</strong>
                        </td>
                      </ng-container>

                      <ng-container matColumnDef="codes">
                        <th mat-header-cell *matHeaderCellDef>Code Change</th>
                        <td mat-cell *matCellDef="let request">
                          <div class="code-change-inline">
                            <span class="old-code">{{ request.currentCode }}</span>
                            <mat-icon>arrow_forward</mat-icon>
                            <span class="new-code">{{ request.requestedCode }}</span>
                          </div>
                        </td>
                      </ng-container>

                      <ng-container matColumnDef="actions">
                        <th mat-header-cell *matHeaderCellDef>Actions</th>
                        <td mat-cell *matCellDef="let request">
                          <div class="action-buttons-inline">
                            <button
                              mat-icon-button
                              color="primary"
                              (click)="approveCodeChangeRequest(request.uuid)"
                              matTooltip="Approve"
                            >
                              <mat-icon>check</mat-icon>
                            </button>
                            <button
                              mat-icon-button
                              color="warn"
                              (click)="rejectCodeChangeRequest(request.uuid)"
                              matTooltip="Reject"
                            >
                              <mat-icon>close</mat-icon>
                            </button>
                          </div>
                        </td>
                      </ng-container>

                      <tr mat-header-row *matHeaderRowDef="['user', 'codes', 'actions']"></tr>
                      <tr mat-row *matRowDef="let row; columns: ['user', 'codes', 'actions'];"></tr>
                    </table>
                  </div>
                }
              </div>
            }

            <!-- Pending Payout Requests -->
            @if (canManagePayouts()) {
              <div class="admin-section payout-requests-section">
                <h3>Pending Cash Payout Requests</h3>

                @if (loadingPayoutRequests) {
                  <div class="loading-container-small">
                    <mat-spinner diameter="30"></mat-spinner>
                    <span>Loading requests...</span>
                  </div>
                } @else if (pendingPayoutRequests.length === 0) {
                  <div class="no-data-small">No pending payout requests</div>
                } @else {
                  <div class="requests-table">
                    <table mat-table [dataSource]="pendingPayoutRequests" class="compact-table">
                      <ng-container matColumnDef="affiliate">
                        <th mat-header-cell *matHeaderCellDef>Affiliate</th>
                        <td mat-cell *matCellDef="let payout">
                          <div class="affiliate-info">
                            <strong>{{ payout.affiliate.username }}</strong>
                            <small>ID: {{ payout.affiliate.uuid }}</small>
                          </div>
                        </td>
                      </ng-container>

                      <ng-container matColumnDef="amount">
                        <th mat-header-cell *matHeaderCellDef>Amount</th>
                        <td mat-cell *matCellDef="let payout">
                          <div class="amount-info">
                            <div>{{ payout.affiliateCreditAmount.toLocaleString() }} credits</div>
                            <div class="usd-amount">${{ centsToDollars(payout.targetAmount) }} USD</div>
                          </div>
                        </td>
                      </ng-container>

                      <ng-container matColumnDef="requested">
                        <th mat-header-cell *matHeaderCellDef>Requested</th>
                        <td mat-cell *matCellDef="let payout">
                          {{ formatDate(payout.createdAt) }}
                        </td>
                      </ng-container>

                      <ng-container matColumnDef="actions">
                        <th mat-header-cell *matHeaderCellDef>Actions</th>
                        <td mat-cell *matCellDef="let payout">
                          <div class="action-buttons-inline">
                            <button
                              mat-icon-button
                              color="primary"
                              (click)="viewPayoutDetails(payout.uuid)"
                              matTooltip="View Details"
                            >
                              <mat-icon>visibility</mat-icon>
                            </button>
                            <button
                              mat-icon-button
                              color="accent"
                              (click)="approvePayoutRequest(payout.uuid)"
                              matTooltip="Approve"
                            >
                              <mat-icon>check</mat-icon>
                            </button>
                            <button
                              mat-icon-button
                              color="warn"
                              (click)="rejectPayoutRequest(payout.uuid)"
                              matTooltip="Reject"
                            >
                              <mat-icon>close</mat-icon>
                            </button>
                          </div>
                        </td>
                      </ng-container>

                      <tr mat-header-row *matHeaderRowDef="['affiliate', 'amount', 'requested', 'actions']"></tr>
                      <tr mat-row *matRowDef="let row; columns: ['affiliate', 'amount', 'requested', 'actions'];"></tr>
                    </table>
                  </div>
                }
              </div>
            }
          </mat-card-content>
        </mat-card>
      }
    </div>
  }

  <!-- Shared Admin Control Panel - Displayed after eligible/not-eligible sections -->
  @if (hasAnyAdminPermission()) {
    <ng-container *ngTemplateOutlet="adminControlPanel"></ng-container>
  }
</div>

<!-- Admin Control Panel Template (Reusable) -->
<ng-template #adminControlPanel>
  <mat-card class="admin-control-panel">
    <mat-card-content>
      <h2>Affiliate Admin Control Panel</h2>
      <p class="admin-notice">
        <mat-icon>admin_panel_settings</mat-icon>
        You have administrative access. Use the controls below to manage the affiliate program.
      </p>

      <!-- Platform Financial Stats (Admin Only) -->
      @if (isAdmin()) {
        <div class="admin-section financial-stats-section">
          <!-- ...existing financial stats code... -->
        </div>

        <!-- Affiliate Network Graph (Admin Only) -->
        <div class="admin-section graph-section">
          <!-- ...existing graph section code... -->
        </div>

        <!-- Global Program Settings (Admin Only) -->
        <div class="admin-section program-settings-section">
          <!-- ...existing program settings code... -->
        </div>

        <!-- User Account Management (Admin Only) -->
        <div class="admin-section user-management-section">
          <!-- ...existing user management code... -->
        </div>
      }

      <!-- Pending Code Change Requests (Code Approvers) -->
      @if (canApproveCodeChanges()) {
        <div class="admin-section code-requests-section">
          <!-- ...existing code requests code... -->
        </div>
      }

      <!-- Pending Payout Requests (Payout Managers) -->
      @if (canManagePayouts()) {
        <div class="admin-section payout-requests-section">
          <!-- ...existing payout requests code... -->
        </div>
      }
    </mat-card-content>
  </mat-card>
</ng-template>
