// Host component constraints
:host {
  overflow-x: hidden;
  display: block;

  box-sizing: border-box;
  width: 100%;
  max-width: 100vw;
}

// News container basics
.news-container {
  mat-list-item {
    padding: 0;
  }

  .news-item {
    height: auto;
    margin-bottom: 8px;
    padding-bottom: 2px;
  }

  // Scope images properly within news description
  .news-description img {
    float: left;

    width: auto;
    max-width: 200px;
    height: auto;
    max-height: 200px;
    margin-right: 16px;
    margin-bottom: 16px;
  }
}

// Top card header
.create-podcast-card {
  flex-shrink: 0;

  padding-top: 16px;
  border-bottom: 1px solid var(--md-sys-color-outline-variant);
  border-radius: 0;

  background-color: var(--md-sys-color-surface-container-low);
  box-shadow: none;

  .before-select-podcast & {
    position: sticky;
    z-index: 50;
    top: 0;
  }

  .content-header {
    display: flex;
    align-items: center;
    justify-content: space-between;

    min-height: 40px;
    padding-top: 0;
    padding-bottom: 10px;
    padding-inline: 30px;

    .select-right-podcasts {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      row-gap: 8px;
      align-items: center;

      mat-form-field {
        &.podcast-select-field {
          width: 300px;
          max-width: 100%;
        }

        &.time-select-field {
          width: 134px;
          max-width: 100%;
        }

        @media screen and (width <= 576px) {
          width: 100%;
        }
      }

      .no-rss-feeds-message {
        cursor: help;

        display: flex;
        gap: 8px;
        align-items: center;

        padding: 8px 16px;
        border: 1px solid var(--md-sys-color-outline-variant);
        border-radius: 8px;

        font-size: 14px;
        font-weight: 500;
        color: var(--md-sys-color-on-surface-variant);

        background-color: var(--md-sys-color-surface-container-high);

        .warning-icon {
          width: 16px;
          height: 16px;

          font-size: 16px;
          color: var(--md-extended-color-warning-color);
          vertical-align: middle;
        }

        mat-icon {
          vertical-align: middle;
        }

        @media screen and (width <= 576px) {
          justify-content: center;
          width: 100%;
        }
      }

      .time-field {
        width: 134px;
        max-width: 100%;
      }

      @media screen and (width <= 576px) {
        width: 100%;
      }
    }

    @media screen and (width <= 900px) {
      flex-direction: column;
      gap: 16px;
      align-items: flex-start;
      min-height: auto;
    }

    @media screen and (width <= 576px) {
      flex-direction: column;
      gap: 0;
      align-items: flex-start;

      min-height: auto;
      padding-inline: 16px;
    }
  }
}

// News list container - needed for proper flex and scrolling
.news-list-container {
  overflow: hidden;
  display: flex;
  flex: 1;
  flex-direction: column;

  min-height: 0;
}

// Main content area
.middle-card {
  position: relative;

  overflow: hidden;
  display: flex;
  flex: 1;
  flex-direction: row;
  gap: 0;

  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  min-height: 0;

  .blocked-badge {
    display: inline-flex;
    flex-shrink: 0;
    gap: 4px;
    align-items: center;

    padding: 4px 8px;
    border: 1px solid color-mix(in srgb, var(--md-sys-color-error) 30%, transparent);
    border-radius: 8px;

    font-size: 12px;
    font-weight: 500;
    color: var(--md-sys-color-error);
    white-space: nowrap;

    background-color: color-mix(in srgb, var(--md-sys-color-error-container) 10%, transparent);

    mat-icon {
      width: 16px;
      height: 16px;
      font-size: 16px;
    }
  }

  .news-list {
    overflow-x: hidden;
    overflow-y: auto;
    display: flex;
    flex: 1;
    flex-direction: column;

    box-sizing: border-box;
    min-width: 0;
    padding: 12px 16px;

    background-color: var(--md-sys-color-surface-container);

    &.newsListSelected {
      @media screen and (width <= 576px) {
        display: none;
      }
    }
  }

  .news-card {
    cursor: pointer;
    display: flex;
    gap: 16px;
    align-items: center;

    &:hover .news-card-wrapper {
      background: var(--md-sys-color-surface-container-high);
    }

    mat-checkbox {
      flex-shrink: 0;
    }

    .news-card-wrapper {
      overflow: hidden;
      flex: 1;

      min-width: 0;
      padding: 16px;
      border: 1px solid var(--md-sys-color-outline-variant);
      border-radius: 8px;

      background: var(--md-sys-color-surface-container);

      transition: background-color 0.2s ease;

      &.newsSelected {
        border-color: var(--md-sys-color-secondary);
        background: var(--md-sys-color-surface-container-high);
      }
    }

    .news-content {
      display: flex;
      gap: 16px;
      align-items: center;
      justify-content: space-between;

      min-width: 0;

      @media screen and (width <= 576px) {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    .news-header {
      overflow: hidden;
      flex: 1;
      min-width: 0;
      max-width: calc(100% - 150px);

      .title {
        display: flex;
        flex-wrap: nowrap;
        gap: 8px;
        align-items: center;

        min-width: 0;

        a.external-link {
          overflow: hidden;

          // Remove flex:1 so link only covers text, not full width
          display: inline;

          font-size: 14px;
          font-weight: 500;
          /* stylelint-disable-next-line declaration-property-value-disallowed-list */
          line-height: 1.4;
          color: var(--md-sys-color-on-surface);
          text-decoration: none;
          text-overflow: ellipsis;
        }
      }

      .source {
        display: flex;
        gap: 8px;
        align-items: center;
        margin-top: 4px;
      }
    }

    .date {
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      gap: 8px;
      align-items: flex-end;

      min-width: fit-content;
      padding-left: 16px;

      span {
        font-size: 11px;
        font-weight: 400;
        color: var(--md-sys-color-on-surface-variant);
        white-space: nowrap;
      }

      @media screen and (width <= 576px) {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;

        width: 100%;
        padding-left: 0;
      }
    }
  }

  .news-card:has(a.external-link:hover) .news-card-wrapper.newsSelected {
    border-color: var(--md-sys-color-outline-variant);
    background: var(--md-sys-color-surface-container);
  }

  // Extracted to reduce nesting depth
  .news-card .source p {
    margin: 0;
    font-size: 12px;
    font-weight: 400;
    color: var(--md-sys-color-on-surface-variant);
  }

  .news-card .news-header .title a.external-link:hover {
    color: var(--md-sys-color-primary);
    text-decoration: underline;
  }

  .news-detail-section {
    position: relative;

    overflow: hidden;
    display: none;
    flex: 0 0 auto;

    box-sizing: border-box;
    width: 0;

    transition: width 0.3s ease-in-out;

    &.newsDetailSelectedSection {
      display: block;
    }

    @media screen and (width <= 576px) {
      position: fixed;
      z-index: 555;
      top: 0;
      right: 0;

      width: 90%;
      height: 100vh;
    }
  }

  .resize-handle {
    cursor: col-resize;

    position: absolute;
    z-index: 10;
    top: 0;
    bottom: 0;
    left: 0;

    width: 6px;

    background-color: transparent;

    transition: background-color 0.2s ease;

    &::before {
      content: '';

      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);

      width: 2px;
      height: 40px;
      border-radius: 4px;

      background-color: var(--md-sys-color-outline-variant);

      transition: background-color 0.2s ease;
    }

    &:hover,
    &.resizing {
      background-color: var(--md-sys-color-secondary);
    }

    &:hover::before,
    &.resizing::before {
      background-color: var(--md-sys-color-on-secondary);
    }
  }

  .news-details {
    overflow-x: hidden;
    overflow-y: auto;
    display: flex;
    flex-direction: column;

    box-sizing: border-box;
    width: 100%;
    height: 100%;
    padding: 16px 30px 40px;
    padding-left: 36px;
    border-left: 1px solid var(--md-sys-color-outline-variant);

    color: var(--md-sys-color-on-surface);

    background-color: var(--md-sys-color-surface-container);
    box-shadow: -4px 0 12px color-mix(in srgb, var(--md-sys-color-shadow) 10%, transparent);


    h3 {
      margin-top: 16px;
      margin-bottom: 12px;

      font-size: 14px;
      font-weight: 500;
      color: var(--md-sys-color-on-surface-variant);
    }

    p {
      max-width: 100%;

      font-size: 14px;
      font-weight: 400;
      color: var(--md-sys-color-on-surface);
      overflow-wrap: break-word;
    }

    .news-description,
    .news-description * {
      max-width: 100%;
      overflow-wrap: break-word;
    }

    button {
      flex-shrink: 0;

      min-width: fit-content;
      margin-top: 8px;
      margin-bottom: 16px;
      padding: 8px 16px;
      border-radius: 8px;

      font-weight: 600;
      white-space: nowrap;

      // Let Material color directive handle background and text colors

      &.regenerate-summary-btn {
        margin-left: 8px;
      }

      &:disabled {
        opacity: 0.7;
      }

      & + button {
        margin-left: 8px;
      }
    }

    mat-divider {
      margin: 16px 0;
    }

    @media screen and (width <= 576px) {
      padding: 16px;
    }
  }

  .description-title {
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--md-sys-color-outline-variant);

    .cross-icon {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 16px;

      span {
        cursor: pointer;

        display: inline-flex;
        align-items: center;
        justify-content: center;

        width: 32px;
        height: 32px;
        border-radius: 8px;

        color: var(--md-sys-color-on-surface);

        transition: background-color 0.2s ease;

        &:hover {
          background-color: var(--md-sys-color-surface-container-high);
        }

        app-svg-icon {
          width: 16px;
          height: 16px;
        }
      }
    }

    .title a.external-link {
      display: block;

      font-size: 16px;
      font-weight: 600;
      color: var(--md-sys-color-on-surface);
      text-decoration: none;
      overflow-wrap: break-word;

      &:hover {
        color: var(--md-sys-color-secondary);
        text-decoration: underline;
      }
    }

    .source {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-bottom: 16px;

      p {
        margin: 0;
        font-size: 13px;
        font-weight: 400;
        color: var(--md-sys-color-on-surface-variant);

        strong {
          font-weight: 500;
          color: var(--md-sys-color-on-surface);
        }
      }
    }

    .read-btn {
      display: inline-flex;
      gap: 8px;
      align-items: center;

      padding: 8px 16px;
      border: 1px solid var(--md-sys-color-outline-variant);

      color: var(--md-sys-color-tertiary);

      background: transparent;

      &:hover {
        background: var(--md-sys-color-surface-container-high);
      }
    }
  }
}

// Flattened selectors to reduce specificity
.description-title .title a.external-link:hover {
  color: var(--md-sys-color-secondary);
  text-decoration: underline;
}

.description-title .source p strong {
  font-weight: 500;
  color: var(--md-sys-color-on-surface);
}

// Table controls
.table-controls {
  display: flex;
  gap: 16px;
  align-items: center;
  justify-content: space-between;

  margin-bottom: 16px;

  &.mobile {
    display: none;
  }

  .search-filter {
    display: flex;
    gap: 8px;
    align-items: center;

    @media screen and (width <= 576px) {
      width: 100%;
      padding: 4px 6px;
      border: 1px solid var(--md-sys-color-outline-variant);
      border-radius: 8px;
    }
  }

  .input-search-div {
    display: flex;
    gap: 8px;
    align-items: center;

    width: 322px;
    padding: 0 8px;
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 8px;

    background-color: var(--md-sys-color-surface-container-low);

    input {
      width: 100%;
      height: 36px;
      border: 0;

      color: var(--md-sys-color-on-surface-variant);

      background: transparent;
    }

    @media screen and (width <= 576px) {
      width: 100%;
      padding: 0;
      border: 0;
    }
  }

  .filter-button {
    padding: 8px 16px;
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 8px;

    font-weight: 500;
    color: var(--md-sys-color-on-surface);

    background-color: var(--md-sys-color-surface-container-low);

    @media screen and (width <= 576px) {
      min-width: auto;
      padding: 0;
      border: 0;

      color: var(--md-sys-color-on-surface);

      background: transparent;
    }
  }

  @media screen and (width <= 576px) {
    flex-direction: column;
    width: 100%;

    &.desktop {
      display: none;
    }

    &.mobile {
      display: flex;
    }
  }
}

// Before select podcast state
.before-select-podcast {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;

  .news-before-container {
    max-width: 730px;
    margin: auto;
    padding: 0 16px;

    h3 {
      margin: 0;

      font-size: 32px;
      font-weight: 600;
      color: var(--md-sys-color-on-surface);
      text-align: center;

      @media screen and (width <= 576px) {
        font-size: 24px;
      }
    }

    p {
      max-width: 600px;
      margin: 8px auto 0;
      color: var(--md-sys-color-on-surface-variant);
      text-align: center;

      @media screen and (width <= 576px) {
        font-size: 14px;
      }
    }

    .before-select-right-podcasts {
      margin-top: 30px;
      text-align: center;

      .fields {
        display: flex;
        gap: 8px;
        justify-content: center;

        @media screen and (width <= 576px) {
          flex-direction: column;
          align-items: center;
        }
      }

      .podcast-field-wrapper {
        position: relative;
        display: inline-block;

        .podcast-loading-spinner {
          pointer-events: none;

          position: absolute;
          z-index: 10;
          top: 50%;
          right: 8px;
          transform: translateY(-50%);
        }
      }

      button {
        border-radius: 8px;

        // Let Material color directive handle background and text colors
      }
    }
  }
}

// After select podcast state
.after-select-podcast {
  overflow: visible; // Changed from hidden to allow detail panel to show
  display: flex;
  flex-direction: column;
  height: calc(100vh - 128px);
}

// Next button
.next-btn {
  display: flex;
  align-items: center;
  justify-content: center;

  width: 28px;
  height: 28px;
  border: 1px solid var(--md-sys-color-outline-variant);
  border-radius: 8px;

  color: var(--md-sys-color-on-surface);

  span {
    font-size: 16px;
    color: inherit;
  }
}

// Select all button
.select-btn {
  display: flex;
  gap: 8px;
  align-items: center;

  padding: 8px;
  border: 1px solid var(--md-sys-color-outline-variant);
  border-radius: 8px;

  background: var(--md-sys-color-surface-container);

  .custom-select-all {
    cursor: pointer;
    user-select: none;

    display: flex;
    gap: 8px;
    align-items: center;

    font-size: 16px;
    font-weight: 500;
    color: var(--md-sys-color-on-surface);

    input[type='checkbox'] {
      display: none;
    }

    .custom-checkbox {
      position: relative;

      display: flex;
      align-items: center;
      justify-content: center;

      width: 16px;
      height: 16px;
      border: 2px solid var(--md-sys-color-secondary);
      border-radius: 4px;

      background: var(--md-sys-color-surface-container);

      transition: background 0.2s, border 0.2s;
    }

    input[type='checkbox']:checked + .custom-checkbox {
      border-color: var(--md-sys-color-secondary);
      background: var(--md-sys-color-secondary);
    }

    input[type='checkbox']:checked + .custom-checkbox::after {
      content: '';

      position: absolute;
      top: 4px;
      left: 4px;
      transform: rotate(-45deg);

      display: block;

      width: 8px;
      height: 4px;
      border-bottom: 2px solid white;
      border-left: 2px solid white;
    }

    input[type='checkbox']:indeterminate + .custom-checkbox {
      border-color: var(--md-sys-color-secondary);
      background: transparent;
    }

    input[type='checkbox']:indeterminate + .custom-checkbox::after {
      content: '';

      position: absolute;

      display: block;

      width: 12px;
      height: 12px;
      border-radius: 4px;

      background: var(--md-sys-color-secondary);
    }
  }

  .select-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--md-sys-color-on-surface);
  }

  @media screen and (width <= 576px) {
    padding: 0;
    border: 0;
    background: transparent;

    &.desktop {
      display: none;
    }
  }
}

// Categories and Tags
.metadata-section {
  margin: 16px 0;

  h3 {
    margin-bottom: 12px;
    font-size: 16px;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
  }
}

.categories-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.category-badge {
  display: inline-block;

  padding: 6px 12px;
  border: 1px solid var(--md-sys-color-outline-variant);
  border-radius: 8px;

  font-size: 13px;
  font-weight: 500;
  color: var(--md-sys-color-on-surface);
  white-space: nowrap;

  background: var(--md-sys-color-surface-container-high);
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.news-tag {
  display: inline-flex;
  align-items: center;

  padding: 6px 12px;
  border-radius: 8px;

  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;

  transition: transform 0.2s ease;

  &:hover {
    transform: translateY(-1px);
  }
}

// Political tags - Use MD3 semantic colors
.tag-political-democratic {
  color: var(--md-extended-color-info-on-color);
  background: var(--md-extended-color-info-color);
}

.tag-political-republican {
  color: var(--md-sys-color-on-error);
  background: var(--md-sys-color-error);
}

.tag-political-neutral {
  color: var(--md-sys-color-on-surface-variant);
  background: var(--md-sys-color-surface-container-high);
}

// Financial sentiment tags - Use MD3 semantic colors
.tag-sentiment-bullish {
  color: var(--md-extended-color-success-on-color);
  background: var(--md-extended-color-success-color);
}

.tag-sentiment-bearish {
  color: var(--md-sys-color-on-error);
  background: var(--md-sys-color-error);
}

.tag-sentiment-neutral {
  color: var(--md-extended-color-warning-on-color);
  background: var(--md-extended-color-warning-color);
}

// Tone tags - Use MD3 semantic colors
.tag-tone-urgent {
  color: var(--md-sys-color-on-error);
  background: var(--md-sys-color-error);
}

.tag-tone-calm {
  color: var(--md-extended-color-info-on-color);
  background: var(--md-extended-color-info-color);
}

.tag-tone-analytical {
  color: var(--md-sys-color-on-tertiary);
  background: var(--md-sys-color-tertiary);
}

.tag-tone-sensational {
  color: var(--md-sys-color-on-secondary);
  background: var(--md-sys-color-secondary);
}

// Content type tags - Use MD3 semantic colors
.tag-content-breaking {
  color: var(--md-sys-color-on-error);
  background: var(--md-sys-color-error);
}

.tag-content-analysis {
  color: var(--md-sys-color-on-primary);
  background: var(--md-sys-color-primary);
}

.tag-content-opinion {
  color: var(--md-sys-color-on-tertiary);
  background: var(--md-sys-color-tertiary);
}

.tag-content-data {
  color: var(--md-sys-color-on-secondary);
  background: var(--md-sys-color-secondary);
}

// Default tag
.tag-default {
  border: 1px solid var(--md-sys-color-outline-variant);
  color: var(--md-sys-color-on-surface);
  background: var(--md-sys-color-surface-container-high);
}

// Responsive
@media (width <= 576px) {
  .categories-container,
  .tags-container {
    gap: 8px;
  }

  .category-badge,
  .news-tag {
    padding: 4px 8px;
    font-size: 11px;
  }
}

// Flattened selectors to avoid deep nesting
.news-item {
  .source {
    mat-icon {
      width: 16px;
      height: 16px;
      font-size: 16px;
      color: var(--md-sys-color-on-surface-variant);
    }

    p strong {
      font-weight: 500;
    }
  }
}
